# GEMINI_API_KEY: clé API Google GenAI pour les agents.
GEMINI_API_KEY=""

# Google OAuth 2.0 (Créer des credentials sur https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# JWT secret pour signer les tokens d'authentification (générer une chaîne longue aléatoire)
JWT_SECRET=""

# App URL utilisée pour les callbacks OAuth et les liens internes.
APP_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"
